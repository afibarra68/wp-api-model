# =============================================================================
# WhatsApp Control — variables del backend (+ VITE_* para frontend)
# =============================================================================
# 1. Copia:      cp config.env.example config.env
# 2. Edita config.env
# 3. Sincroniza: ./scripts/sync-env.sh  → backend/.env y ../frontend/.env
# =============================================================================


# =============================================================================
# BACKEND — App
# =============================================================================
NODE_ENV=development
PORT=3000
API_PORT=3000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000


# =============================================================================
# BACKEND — PostgreSQL (única base de datos)
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=whatsapp_control
POSTGRES_SSL=false
POSTGRES_CA_CERT=
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/whatsapp_control
# DigitalOcean: POSTGRES_SSL=true, POSTGRES_PORT=25060, POSTGRES_CA_CERT (PEM en una línea con \n)


# =============================================================================
# BACKEND — Cola de envío
# =============================================================================
QUEUE_DRIVER=memory
REDIS_URL=redis://localhost:6379
SEND_RATE_PER_SECOND=2
CRON_SECRET=


# =============================================================================
# BACKEND — JWT y autenticación
# =============================================================================
JWT_SECRET=dev-cambia-esto-por-uno-largo
JWT_REFRESH_SECRET=dev-cambia-esto-tambien-distinto
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=10


# =============================================================================
# BACKEND — Usuario admin inicial (seed)
# =============================================================================
SEED_ADMIN_EMAIL=admin@local.test
SEED_ADMIN_PASSWORD=Cambiar.Esto.123
SEED_MOCKUPS=true


# =============================================================================
# BACKEND — Proveedor de envío WhatsApp
# =============================================================================
PROVIDER=meta-cloud
WEBHOOK_VERIFY_TOKEN=dev-verify-token


# =============================================================================
# BACKEND — Meta Cloud API
# =============================================================================
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v20.0
WHATSAPP_PRODUCT_POLICY=
WHATSAPP_MESSAGE_ACTIVITY_SHARING=


# =============================================================================
# BACKEND — Evolution API (opcional)
# =============================================================================
EVOLUTION_BASE_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=


# =============================================================================
# FRONTEND — Vite (solo si usas el repo frontend local)
# =============================================================================
VITE_API_URL=http://localhost:3000/api/v1
VITE_EVENT_NAME=Evento Cristiano
VITE_EVENT_SHORT=✝
VITE_EVENT_TAGLINE=Panel de mensajería del evento
