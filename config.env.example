# =============================================================================
# WhatsApp Control — backend + frontend (editar y ./scripts/sync-env.sh)
# =============================================================================
# 1. Copia:      cp config.env.example config.env
# 2. Edita config.env (NO subir secretos a git)
# 3. Sincroniza: ./scripts/sync-env.sh  → .env y frontend/.env
# =============================================================================

# =============================================================================
# BACKEND — App
# =============================================================================
NODE_ENV=production
PORT=3000
API_PORT=3000
CORS_ORIGINS=https://whatsapp-gesture-frontend-app.vercel.app,http://localhost:5173,http://localhost:3000

# =============================================================================
# BACKEND — PostgreSQL (DigitalOcean)
# =============================================================================
POSTGRES_HOST=db-XXXX.db.ondigitalocean.com
POSTGRES_PORT=25060
POSTGRES_USER=doadmin
POSTGRES_PASSWORD=cambia-esto
POSTGRES_DB=modellerdbapiwtsap
POSTGRES_SSL=true
POSTGRES_CA_CERT=
DATABASE_URL=postgresql://doadmin:cambia-esto@db-XXXX.db.ondigitalocean.com:25060/modellerdbapiwtsap

# =============================================================================
# BACKEND — Cola
# =============================================================================
QUEUE_DRIVER=bullmq
REDIS_URL=redis://localhost:6379
SEND_RATE_PER_SECOND=2
CAMPAIGN_DEFAULT_DIAS=7
CRON_SECRET=

# =============================================================================
# BACKEND — JWT
# =============================================================================
JWT_SECRET=genera-un-secreto-largo
JWT_REFRESH_SECRET=genera-otro-secreto-distinto
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# =============================================================================
# BACKEND — Seed
# =============================================================================
SEED_ADMIN_EMAIL=admin@local.test
SEED_ADMIN_PASSWORD=Cambiar.Esto.123
SEED_MOCKUPS=false

# =============================================================================
# BACKEND — WhatsApp / Meta
# =============================================================================
PROVIDER=meta-cloud
WEBHOOK_VERIFY_TOKEN=cambia-esto
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v25.0
WHATSAPP_PRODUCT_POLICY=
WHATSAPP_MESSAGE_ACTIVITY_SHARING=

# =============================================================================
# BACKEND — Evolution (opcional)
# =============================================================================
EVOLUTION_BASE_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=

# =============================================================================
# FRONTEND — Vite
# =============================================================================
VITE_API_URL=https://whatsapiteller-ia7n8.ondigitalocean.app/api/v1
VITE_EVENT_NAME=Evento Cristiano
VITE_EVENT_SHORT=✝
VITE_EVENT_TAGLINE=Panel de mensajería del evento
