# ===== App =====
NODE_ENV=production
PORT=3000
API_PORT=3000
CORS_ORIGINS=https://tu-frontend.vercel.app,http://localhost:5173

# ===== PostgreSQL (única base de datos) =====
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=cambia-esto-en-produccion
POSTGRES_DB=whatsapp_control
POSTGRES_SSL=false
# Opcional (DigitalOcean): PEM en una línea con \\n entre líneas
POSTGRES_CA_CERT=
DATABASE_URL=postgresql://postgres:cambia-esto-en-produccion@localhost:5432/whatsapp_control
# DigitalOcean: POSTGRES_SSL=true y puerto 25060 (no añadir sslmode a DATABASE_URL)

# ===== Cola =====
QUEUE_DRIVER=bullmq
REDIS_URL=redis://redis:6379
SEND_RATE_PER_SECOND=2
CAMPAIGN_DEFAULT_DIAS=7
CRON_SECRET=

# ===== JWT =====
JWT_SECRET=genera-con-openssl-rand-hex-32
JWT_REFRESH_SECRET=otro-secreto-distinto
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# ===== Seed =====
SEED_ADMIN_EMAIL=admin@local.test
SEED_ADMIN_PASSWORD=Cambiar.Esto.123
SEED_MOCKUPS=false

# ===== Integración (fallback; preferir POST /integrations) =====
PROVIDER=meta-cloud
WEBHOOK_VERIFY_TOKEN=dev-verify-token
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v20.0
WHATSAPP_PRODUCT_POLICY=
WHATSAPP_MESSAGE_ACTIVITY_SHARING=

# ===== Evolution (opcional) =====
EVOLUTION_BASE_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=
