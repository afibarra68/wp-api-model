# ===== App =====
NODE_ENV=production
PORT=3000
API_PORT=3000
CORS_ORIGINS=https://tu-frontend.vercel.app,http://localhost:5173

# ===== PostgreSQL (integraciones + schema de negocio) =====
POSTGRES_USER=postgres
POSTGRES_PASSWORD=cambia-esto-en-produccion
POSTGRES_DB=whatsapp_control
DATABASE_URL=postgresql://postgres:cambia-esto-en-produccion@postgres:5432/whatsapp_control
POSTGRES_SSL=false

# ===== MongoDB (datos de negocio: clientes, campañas, logs) =====
DB_DRIVER=mongo
MONGO_URI=mongodb://mongodb:27017/whatsapp_control

# ===== Cola =====
QUEUE_DRIVER=bullmq
REDIS_URL=redis://redis:6379
SEND_RATE_PER_SECOND=2

# ===== JWT =====
JWT_SECRET=genera-con-openssl-rand-hex-32
JWT_REFRESH_SECRET=otro-secreto-distinto
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# ===== Seed =====
SEED_ADMIN_EMAIL=admin@local.test
SEED_ADMIN_PASSWORD=Cambiar.Esto.123
SEED_MOCKUPS=false

# ===== Integración (fallback; preferir POST /integrations en Postgres) =====
PROVIDER=meta-cloud
WEBHOOK_VERIFY_TOKEN=dev-verify-token
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v20.0
WHATSAPP_PRODUCT_POLICY=
WHATSAPP_MESSAGE_ACTIVITY_SHARING=

# ===== Evolution (opcional) =====
EVOLUTION_BASE_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=
