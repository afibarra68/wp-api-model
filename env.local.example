# Copia a .env para desarrollo local sin WhatsApp API
# Copy-Item env.local.example .env

NODE_ENV=development
PORT=3001
API_PORT=3001
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# PostgreSQL en Docker (volumen persistente wc-whatsapp-postgres-data)
# false = usar un PostgreSQL ya instalado en el host
USE_DOCKER_POSTGRES=true

# PostgreSQL local de prueba
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=telodijecomma
POSTGRES_DB=whatsapp_control
POSTGRES_SSL=false
DATABASE_URL=postgresql://admin:telodijecomma@localhost:5432/whatsapp_control

QUEUE_DRIVER=memory
SEND_RATE_PER_SECOND=2

JWT_SECRET=dev-local-jwt-secret-change-in-prod
JWT_REFRESH_SECRET=dev-local-refresh-secret-change-in-prod
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

SEED_ADMIN_EMAIL=admin@local.test
SEED_ADMIN_PASSWORD=Cambiar.Esto.123
SEED_MOCKUPS=false

PROVIDER=simulation
WEBHOOK_VERIFY_TOKEN=dev-verify-token

WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
